<div class="memo-header-row">
  <div class="memo-date"><%= (memo.updated_at || DateTime.now).strftime("%B %e, %Y • %I:%M %p") %> UTC</div>
</div>
<p class="memo-text">
  <%= form_with model: memo, format: :turbo_stream, class: "memo-form",
  data: { turbo_stream: true } do |f| %>
    <%= f.text_area :text %>
    <%= f.hidden_field :kind, value: memo.kind  %>
    <%= f.hidden_field :referrent_id, value: memo.referrent_id %>
    <% if memo.persisted? %>
      <%= f.submit "Save", class: "button small secondary", style:"margin-top:1rem;" %>
      <%= link_to "Cancel", memo, data: { turbo_stream: true }, class: "button small secondary", style:"margin-top:1rem;" %>
    <% else %>
      <%= f.submit "Add Memo", class: "button small secondary", style:"margin-top:1rem;" %>
    <% end %>
  <% end %>
</p>