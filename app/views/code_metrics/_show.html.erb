<%= turbo_frame_tag "survey-item-codes", locals: { survey_item: nil } do %>
  <section class="survey-code-selector">
    <div class="survey-code-control">
      <label for="survey-item-codes" class="code-metrics-label">
        Choose Survey Item Codes To Review
      </label>
    
      <%= form_with url: code_metrics_path, format: :turbo_stream, data: { turbo_stream: true }, id: "survey-item-select" do %>
        <% if survey_item.present? %>
          <%= select_tag :survey_item_id, options_from_collection_for_select(survey_items, 'id', 'formatted_identifier', survey_item.id), { include_blank: "Select..." } %>
        <% else %>
          <%= select_tag :survey_item_id, options_from_collection_for_select(survey_items, 'id', 'formatted_identifier'), { include_blank: "Select..." } %>
        <% end %>
      <% end %>
    </div>

    <% if survey_item.present? %>      
      <div class="survey-question-preview">
        <div class="code-metrics-label">
          Associated Survey Question
        </div>
        <p>
          <%= survey_item.prompt %>
        </p>
      </div>
    <% end %>
  </section>

  <% if survey_item.present? %>      
    <section class="code-metrics-summary">
      <div>
        <div class="app-label">
          Code Metrics
        </div>
        <div class="code-metrics-grid">
        
        <div class="code-metrics-item">
          <span class="code-metrics-label">Survey Item</span>
          <span class="code-metrics-value">Q05 of Q29 · LabelWhatever</span>
        </div>
        
        <div class="code-metrics-item">
          <span class="code-metrics-label">Responses</span>
          <span class="code-metrics-value">214</span>
        </div>
        
        <div class="code-metrics-item">
          <span class="code-metrics-label">Unique Codes</span>
          <span class="code-metrics-value">66</span>
        </div>
        
        <div class="code-metrics-item">
          <span class="code-metrics-label">Last Updated</span>
          <span class="code-metrics-value">May 14, 2026 · 4:22 PM</span>
        </div>
      </div>
    </section>
    
    <section class="code-metrics-layout">
      <div class="code-metrics-main">
        <div id="code-frequencies" class="workspace-title-row">
        <div>
          <h2 class="workspace-title">Code Frequencies</h2>
          <p class="workspace-note">
            Frequency indicates how often a researcher-applied code appears across responses to the selected survey item. Metrics do not determine interpretive significance.
          </p>
        </div>
      </div>
    
      <div class="frequency-toolbar">
        <div class="frequency-toolbar-left">
          <span class="code-metrics-label">Display</span>
          <select id="code-frequency-count" class="app-select">
            <option>10 codes</option>
            <option>20 codes</option>
            <option>30 codes</option>
            <option>All codes</option>
          </select>
        </div>
    
        <div class="frequency-toolbar-right">
          <a href="#" class="button small">Frequency ▼</a>
          <a href="#" class="button small secondary">Alphabetical ▲</a>
        </div>
      </div>
  
      <div class="overview-card">
        <div class="frequency-list">
          <div class="frequency-row">
            <div class="frequency-label">
              <span>middle class</span>
              <strong>137</strong>
            </div>
            <div class="frequency-bar-track">
              <div class="frequency-bar" style="width:100%;"></div>
            </div>
          </div>  
        </div>
        <p>
          <a href="#" class="button small secondary">Show all 66 codes</a>
        </p>
      </div>
      
      <div id="representative-excerpts" class="workspace-title-row overview-spaced">
        <div>
          <h2 class="workspace-title">Representative Excerpts</h2>
          <p class="workspace-note">
            Excerpts reconnect code frequency to participant language and preserve qualitative context.
          </p>
    
          <div class="section-inline-control">
            <label for="excerpt-count" class="code-metrics-label">
              Display
            </label>
            <select id="excerpt-count" class="app-select">
              <option>5 excerpts</option>
              <option>10 excerpts</option>
              <option>15 excerpts</option>
            </select>
          </div>
        </div>
      </div>
    
      <div class="excerpt-list">
        
        <article class="excerpt-card">
          <div class="excerpt-meta">
            <span class="tag dark">middle class</span>
            <span class="case-subtext">Persona_014</span>
          </div>
          <p class="excerpt-text">
            “Lorem ipsum dolor sit amet, consectetur adipiscing elit.”
          </p>
        </article>
    
      </div>
    
      <aside class="code-metrics-sidebar" aria-label="Code metrics sidebar">
        <section id="memos" class="sidebar-card white">
          <div class="sidebar-card-title">
            Researcher Memos
          </div>
        </section>
      
        <section class="sidebar-card">
          <details class="sidebar-disclosure" open>
            <summary class="sidebar-card-title disclosure-title">
              Associated Categories
            </summary>
            <div class="empty-state">
              No associated categories yet. Categories will appear as analysis progresses.
            </div>
          </details>
        </section>
      </aside>
    </section>
  <% end %>
<% end %>