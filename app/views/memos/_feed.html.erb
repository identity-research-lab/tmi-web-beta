<ul class="memo-feed">
  <% if memos.any? %>
    <% memos.each do |memo| %>
      <%= render partial: "memos/show", locals: { memo: memo } %>
    <% end %>
  <% else %>
    <li class="memo-entry">
      <p class="memo-text">
        No recent memos.
      </p>
    </li>
    <li class="memo-entry">
      <%= render partial: "/memos/form", locals: { memo: new_memo } %>
    </li>
  <% end %>
</ul>
