<%- title "Categories" %>
<%- active_nav "categories" %>

<section class="app-header dashboard-hero">

  <div class="app-header-copy">
    <div class="app-label">
      <%= @project.name %> · <span class="app-label-dense">Category Development</span>
    </div>
    <h1 class="app-title">Categories</h1>
    <p class="app-description">
      Create, review, revise, and remove analytical categories. Categories organize related researcher-applied codes into higher-level concepts that can later support theme development.
    </p>
  </div>
  <aside aria-label="Category status" class="app-header-panel">
   <div class="app-panel-title">
    Category Status
   </div>
   <div class="app-stats-grid">
    <div class="app-stat">
     <span class="app-stat-value">
      XX
     </span>
     <span class="app-stat-label">
      Categories
     </span>
    </div>
    <div class="app-stat">
     <span class="app-stat-value">
      XXXX
     </span>
     <span class="app-stat-label">
      Project Codes
     </span>
    </div>
    <div class="app-stat">
     <span class="app-stat-value">
      XXXX
     </span>
     <span class="app-stat-label">
      Categorized Codes
     </span>
    </div>
    <div class="app-stat">
     <span class="app-stat-value">
      XXX
     </span>
     <span class="app-stat-label">
      Uncategorized Codes
     </span>
    </div>
   </div>
  </aside>
 </section>

 <section aria-labelledby="create-category-title" class="category-create-section stripe-background">
   <form aria-label="Create a new project category" class="category-create-grid" id="create-category-form">
    <div class="category-create-panel category-create-name">
     <h2 class="category-create-title" id="create-category-title">
      Name New Category
     </h2>
     <input aria-label="New category name" autocomplete="off" class="app-input category-create-input" id="new-category-name" name="category_name" placeholder="Enter a new category name" required="" type="text"/>
    </div>
    <div class="category-create-panel category-create-description">
     <h2 class="category-create-title" id="describe-category-title">
      Describe New Category
     </h2>
     <textarea aria-label="New category description" class="category-create-textarea" id="new-category-memo" name="category_description" placeholder="Describe the new category. This description can be revised later."></textarea>
    </div>
    <div class="category-create-panel category-create-action">
     <h2 class="category-create-title" id="commit-category-title">
      Commit New Category
     </h2>
     <button class="button small category-create-button" type="submit">
      Add New Project Category
     </button>
    </div>
   </form>
  </section>

  <section class="app-section bordered-top categories-list-section">
   <div class="workspace-title-row">
    <div>
     <h2 class="workspace-title">
      Explore Current Project Categories
     </h2>
     <p class="workspace-note">
      Current categories can be edited, renamed, or deleted.
     </p>
    </div>
   </div>
   <div class="category-list-grid">
    <article aria-labelledby="category-card-title-1" class="category-overview-card">
     <div class="category-overview-card-header">
      <div>
       <h3 class="category-overview-card-title" id="category-card-title-1">
        Something
       </h3>
       <div class="case-subtext">
        Edited today &middot; 2:22 PM
       </div>
      </div>
     </div>
     <div class="category-overview-card-meta">
      <span class="tag dark">
       23 codes added
      </span>
     </div>
     <p class="category-overview-card-memo">
      Lorem ipsum is a standard placeholder text used in typography...
     </p>
     <div class="category-overview-card-actions">
      <a class="button small" href="07category-template.html">
       Edit Category
      </a>
      <a class="button small secondary" href="#">
       Rename
      </a>
      <a class="button small delete-button" href="#">
       Delete
      </a>
     </div>
    </article>
  </div>
</section>
