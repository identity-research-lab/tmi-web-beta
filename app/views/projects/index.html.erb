<%- title "Project Dashboard" %>
<%- active_nav "dashboard" %>

<section class="app-header dashboard-hero">

  <div class="app-header-copy">
    <div class="app-label">
      <%= @project.name %> · <span class="app-label-dense">Dashboard</span>
    </div>
    <h1 class="app-title">Project Dashboard</h1>
    <p class="app-description">
      Welcome to your TMI-WEB project dashboard. All TMI-WEB projects begin with the <a href="">TMI-WEB Survey Template</a>. The template can be used with survey platforms such as Google Forms, Qualtrics, or custom survey systems, and supports intersectional analysis by organizing identity dimensions, experiences, and contextual research data into a shared project structure.
    </p>
    <p class="app-description">
      Use this dashboard to start a new project by uploading a TMI-WEB Survey Template (csv), merge updated project data into an active project, review the current state of analysis, enter the dataset through <a href="">participant-centered coding workflows</a> or <a href="">question-centered coding workflows</a>, or continue developing interpretive elements such as codes, categories, themes, and analytical memos.
    </p>
  </div>

  <div>
    <aside class="app-header-panel" aria-label="Project status summary">
      <div class="app-panel-title">Active Project Status</div>
      <div class="app-stats-grid">
        <div class="app-stat">
          <span class="app-stat-value"><%= @case_count %></span>
          <span class="app-stat-label">Cases</span>
        </div>
        <div class="app-stat">
          <span class="app-stat-value"><%= @survey_response_count %></span>
          <span class="app-stat-label">Unique Responses</span>
        </div>
        <div class="app-stat">
          <span class="app-stat-value"><%= @code_count %></span>
          <span class="app-stat-label">Applied Codes</span>
        </div>
        <div class="app-stat">
          <span class="app-stat-value"><%= @category_count %></span>
          <span class="app-stat-label">Categories</span>
        </div>
        <div class="app-stat">
          <span class="app-stat-value"><%= @theme_count %></span>
          <span class="app-stat-label">Themes</span>
        </div>
        <div class="app-stat">
          <span class="app-stat-value"><%= @memo_count %></span>
          <span class="app-stat-label">Researcher memos</span>
        </div>
      </div>
    </aside>
    <ul class="dashboard-actions">
      <li><%= link_to "Manage Project Data", edit_project_path(@project), class: "button" %></li>
    </ul>
  </div>

</section>

<% if SurveyResponse.first %>
  <section class="app-section">
    <div class="section-label">Thematic Coding Pathways</div>
    <div class="dashboard-pathway-grid">
      <article class="dashboard-pathway-card">
        <div class="dashboard-pathway-label">Participant-Centered Thematic Analysis</div>
        <h2 class="dashboard-pathway-title">Pathway: Code by Case</h2>

        <p class="dashboard-pathway-text">
          Enter the dataset through individual participant cases/personas. Review one participant’s responses across the full survey, preserving narrative continuity, situated identity, relational context, and within-case complexity during the coding process.
        </p>

        <div class="frequency-bar-track">
          <% width = (@case_count - @uncoded_case_count) / @case_count.to_f * 100 %>
          <div class="frequency-bar" style="width:<%= width %>%;"></div>
        </div>

        <div class="dashboard-pathway-meta">
          <span class="tag dark"><%= @case_count %> cases</span>
          <span class="tag"><%= @completed_case_count %> coded</span>
          <span class="tag"><%= @in_progress_case_count %> in progress</span>
          <span class="tag"><%= @uncoded_case_count %> uncoded</span>
        </div>

        <%= link_to "Start Coding Cases", personas_path, class: "button small" %>
      </article>

      <article class="dashboard-pathway-card">
        <div class="dashboard-pathway-label">Question-Centered Thematic Analysis</div>
        <h2 class="dashboard-pathway-title">Pathway: Code by Survey Item</h2>

        <p class="dashboard-pathway-text">
          Enter the dataset through individual survey items/questions. Review and code all participant responses associated with a single question, supporting cross-case comparison, thematic pattern recognition, frequency analysis, and emergent interpretive synthesis.
        </p>

        <div class="frequency-bar-track">
          <% width = @survey_response_coded_count / @survey_response_count.to_f * 100 %>
          <div class="frequency-bar" style="width:<%= width %>%;"></div>
        </div>
        <div class="dashboard-pathway-meta">
          <span class="tag dark"><%= @survey_response_count %> survey responses</span>
          <span class="tag"><%= @survey_response_coded_count %> coded</span>
          <span class="tag"><%= @survey_response_count - @survey_response_coded_count %> uncoded</span>
        </div>

        <%= link_to "Start Coding Survey Item Responses", survey_items_path, class: "button small" %>
      </article>

    </div>
  </section>
<% end %>

<section class="app-layout">
  <div class="app-main">
    <div class="workspace-title-row">
      <div>
        <h2 class="workspace-title">
        Recent Activity
        </h2>
        <p class="workspace-note">
        Track recent coding, memoing, imports, and other activity.
        </p>
      </div>
    </div>
    <div class="overview-card">
      <ul class="activity-list">
          <% if @recent_events.any? %>
          <% @recent_events.each do |event| %>
            <%= render partial: "events/show", locals: { event: event } %>
          <% end %>
        <% else %>
          <li class="event-entry">
            <p class="event-text">
              No recent events.
            </p>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
    <aside class="app-sidebar" aria-label="Survey item analysis sidebar">
    <section id="memos" class="sidebar-card white">
      <div class="sidebar-card-title">Researcher Memos</div>
      <%= render partial: "memos/feed", locals: { memos: @memos, memo: nil } %>
    </section>
  </aside>
</section>

